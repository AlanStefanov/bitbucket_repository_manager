# Bitbucket Personal Access Token (OBLIGATORIO)
# Obtén tu token en: Bitbucket Settings → Personal access tokens
# Permisos necesarios: repo:read, workspace:read, read:user
BB_TOKEN=tu_token_aqui

# Bitbucket username or email for authentication (OBLIGATORIO)
BB_USERNAME=tu-email@example.com

# Bitbucket workspace (OBLIGATORIO)
# Ejemplo: si tus repos están en https://bitbucket.org/mi-empresa/
# entonces BB_WORKSPACE=mi-empresa
BB_WORKSPACE=tu-workspace

# Directorio donde se clonarán los repositorios (OPCIONAL)
# Por defecto: ~/bitbucket-repos
# DEV_DIR=/ruta/a/tus/repos

# Git user config for cloned repos (OPCIONAL)
# GIT_USER_NAME=Tu Nombre
# GIT_USER_EMAIL=tu-email@example.com