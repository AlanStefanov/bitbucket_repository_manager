# =============================================================================
# Bitbucket Repository Manager — Configuración
# =============================================================================
# 1. Copia este archivo como .env:  cp .env.example .env
# 2. Completa las variables obligatorias abajo
# 3. ¡Nunca subas .env al repositorio!
# =============================================================================

# Bitbucket Personal Access Token (OBLIGATORIO)
# Cómo obtenerlo: Bitbucket Settings → Personal access tokens
# Permisos necesarios: repo:read, workspace:management
BB_TOKEN=tu_token_aqui

# Tu nombre de usuario o email de Bitbucket (OBLIGATORIO)
BB_USERNAME=tu-email@example.com

# Workspace de Bitbucket (OBLIGATORIO)
# Ej: si tus repos están en https://bitbucket.org/mi-empresa/
# entonces BB_WORKSPACE=mi-empresa
BB_WORKSPACE=tu-workspace

# =============================================================================
# Opcionales
# =============================================================================

# Directorio donde clonar repos (por defecto: ~/bitbucket-repos)
# DEV_DIR=/ruta/a/tus/repos

# Git user config para clones automáticos
# GIT_USER_NAME=Tu Nombre
# GIT_USER_EMAIL=tu-email@example.com